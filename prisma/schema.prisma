generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  SELLER
}

enum VisibilityType {
  GLOBAL
  LOCAL
}

enum OrderStatus {
  PENDING
  CANCELED
  SHIPPED
}

model User {
  id               String   @id @default(uuid()) @db.Uuid
  firstName        String
  lastName         String
  email            String   @unique
  phoneNumber      String   @unique
  state            String
  city             String
  address          String
  address2         String?
  shopName         String?
  role             Role     @default(USER)

  // Seller-specific fields (nullable for non-sellers)
  sellerShopName   String?
  privateCode      String?  @unique
  isGlobalSeller   Boolean  @default(false)

  // Relations
  products         Product[] @relation("SellerProducts")
  ordersAsBuyer    Order[]   @relation("BuyerOrders")
  ordersAsSeller   Order[]   @relation("SellerOrders")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@index([role])
  @@index([state, city])
  @@index([privateCode])
}

model Product {
  id               String         @id @default(uuid()) @db.Uuid
  sellerId         String         @db.Uuid
  name             String
  price            Decimal        @db.Decimal(12, 2)
  visibilityType   VisibilityType
  isActive         Boolean        @default(true)

  seller           User           @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  inventory        Inventory?
  orderItems       OrderItem[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  @@index([sellerId])
  @@index([visibilityType])
  @@index([sellerId, visibilityType])
  @@index([isActive])
}

model Inventory {
  id               String   @id @default(uuid()) @db.Uuid
  productId        String   @unique @db.Uuid
  stock            Int      @default(0)
  reserved         Int      @default(0)
  version          Int      @default(1)

  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([stock])
  @@index([reserved])
}

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @db.Uuid
  sellerId          String      @db.Uuid
  status            OrderStatus @default(PENDING)
  isPaymentReceived Boolean     @default(false)
  paymentId         String?
  totalAmount       Decimal     @db.Decimal(12, 2)

  buyer             User        @relation("BuyerOrders", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  seller            User        @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items             OrderItem[]

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?

  @@index([userId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([sellerId, createdAt])
}

model OrderItem {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @db.Uuid
  productId  String   @db.Uuid
  quantity   Int
  price      Decimal  @db.Decimal(12, 2)

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([orderId, productId])
  @@index([orderId])
  @@index([productId])
}
